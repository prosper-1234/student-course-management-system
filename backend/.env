# Server configuration
PORT=5000
NODE_ENV=development

# SQLite database file location (relative to project root)
DB_PATH=./database/student_courses.db

# Allowed origin(s) for CORS. Use * during development, or a comma
# separated list of exact origins in production, e.g.:
# CORS_ORIGIN=http://localhost:3000,https://your-frontend.com
CORS_ORIGIN=*
